# Required: Anthropic API key the agent uses to call Claude.
ANTHROPIC_API_KEY=

# Required for the Figma cross-reference step (Figma personal access token).
FIGMA_TOKEN=

# Optional: a Firebase CI token so `flutterfire configure` can run non-interactively.
# If empty, you must be logged in via `firebase login` once on this machine.
FIREBASE_TOKEN=

# Optional: override the model. Defaults to claude-opus-4-8.
FA_MODEL=claude-opus-4-8
