# NO ANTHROPIC_API_KEY NEEDED.
# The agent uses the Claude Agent SDK, which shells out to the `claude` CLI binary.
# It uses your existing Claude Code login — no separate API account required.
# Just make sure `claude` is in your PATH and you are logged in (`claude login`).

# Required for the Figma cross-reference step (Figma personal access token).
# Leave empty to skip Figma and use the codebase analysis only.
FIGMA_TOKEN=

# Optional: a Firebase CI token so `flutterfire configure` can run non-interactively.
# If empty, you must be logged in via `firebase login` once on this machine.
FIREBASE_TOKEN=

# Optional: override the Claude model. Defaults to claude-opus-4-8.
# Use claude-sonnet-4-6 to reduce cost.
FA_MODEL=claude-opus-4-8
