# Firebase Analytics Agent — environment variables
# Copy this file to .env and fill in your values.
# Auth uses your Claude Code login (claude login) — no API key needed.

# Optional: Figma personal access token (only needed for fa analyze --figma <url>)
# Get one from: https://www.figma.com/developers/api#access-tokens
FIGMA_TOKEN=

# Optional: Firebase CI token (alternative to running `firebase login` interactively)
# Get one with: firebase login:ci
FIREBASE_TOKEN=

# Optional: Override the default model for all phases
# Defaults: analyze + plan = claude-opus-4-8, everything else = claude-sonnet-4-6
# FA_MODEL=claude-sonnet-4-6
